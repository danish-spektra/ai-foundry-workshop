# ── Azure AI Foundry Workshop — environment variables ──
# ── Foundry project (Home page of your project in https://ai.azure.com) ──
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/

# Required by AIProjectClient.get_openai_client() to build its OpenAI-compatible client.
OPENAI_API_VERSION=2024-10-21

# ── Model deployment names (Build > Models in the Foundry portal) ──
MODEL_DEPLOYMENT_NAME=gpt-5.4
EMBEDDING_MODEL_DEPLOYMENT_NAME=text-embedding-3-large
MICROSOFT_MODEL=Phi-4-reasoning
MODEL_NAME=DeepSeek-V3.2

# ── Azure AI Search (Exercises 3 and 6) ──
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_API_KEY=<your-search-admin-key>
SEARCH_CONNECTION_NAME=<your-ai-search-connection-name-in-foundry>
SEARCH_INDEX_NAME=healthtips-index

# ── Observability (Exercise 5) ──
APPLICATIONINSIGHTS_CONNECTION_STRING=<connection-string-from-application-insights>
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true

# ── Azure identity (Exercise 2 authentication) ──
TENANT_ID=<your-tenant-id>
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
