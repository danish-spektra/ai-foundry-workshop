PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
PROJECT_API_KEY=<your-project-api-key>

# --- Model deployments (deployment names from Foundry > Models + endpoints) ---
MODEL_DEPLOYMENT_NAME=<your-gpt-model-deployment-name>
EMBEDDING_MODEL_DEPLOYMENT_NAME=<your-embedding-model-deployment-name>
MICROSOFT_MODEL=<your-phi-model-deployment-name>
MODEL_NAME=<your-deepseek-model-deployment-name>

# --- Azure AI Search (used by 5-agents-aisearch.ipynb) ---
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_API_KEY=<your-search-admin-key>
SEARCH_CONNECTION_NAME=<your-ai-search-connection-name-in-foundry>

# --- Misc ---
TENANT_ID=<your-tenant-id-from-azure-portal>
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true
AZURE_SDK_TRACING_IMPLEMENTATION=opentelemetry
VITE_API_URL=https://localhost:8003
VITE_DEFAULT_THEME=dark
VITE_API_VERSION=v1
